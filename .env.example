# ===========================================
# Environment Variables - SMANKA School Profile
# ===========================================
# Salin file ini menjadi .env dan isi nilainya
# JANGAN commit file .env ke Git!

# Database PostgreSQL (sudah ada di VPS, dikelola CMS — jangan buat baru)
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=your_database_name

# Database URL (untuk Prisma — dioverride oleh docker-compose saat deploy)
DATABASE_URL="postgresql://your_db_user:your_secure_password@localhost:5433/your_database_name?schema=public"

# Application
NEXT_PUBLIC_API_URL=http://localhost:3000

# YouTube API (opsional)
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY
YOUTUBE_CHANNEL_ID=YOUR_YOUTUBE_CHANNEL_ID
