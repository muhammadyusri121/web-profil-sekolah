generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Modul: Authentication (CMS) ---
enum Role {
  ADMIN
  EDITOR
  AUTHOR
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Modul: Profile & Personnel (GTK) ---
model EducationPersonnel {
  id         String   @id @default(cuid())
  full_name  String
  nip        String?  @unique
  email      String?
  position   String
  image_url  String?
  sort_order Int      @default(0)
  createdAt  DateTime @default(now())

  // Relations
  schedules  SchoolSchedule[]
}

// --- Modul: Articles & Content (Innovation, News, Student Work, etc.) ---
model Post {
  id           String       @id @default(cuid())
  title        String
  slug         String       @unique
  content      String       @db.Text
  category     PostCategory
  images       String[] // Gambar galeri / slider (banyak gambar)
  is_published Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

enum PostCategory {
  SUPERVISI_GURU
  ASAS
  ASAJ
  TKA
  KARYA_SISWA
  HUMAS
  KOMITE
  KEMITRAAN
  DOUBLE_TRACK
  OSIS_MPK
}

// --- Modul: Graduation (Search Feature) ---
model Graduation {
  id              String   @id @default(cuid())
  nisn            String   @unique
  student_name    String
  birthday        String?
  gender          String?
  class_name      String?
  is_graduated    Boolean  @default(false)
  graduation_year Int
  createdAt       DateTime @default(now())
}

// --- Modul: Academic Documents (Files) ---
model AcademicDocument {
  id        String   @id @default(cuid())
  file_name String
  file_path String
  doc_type  DocType
  createdAt DateTime @default(now())
}

enum DocType {
  REGULATION
  TEACHING_MATERIAL
}

// --- Modul: Extracurricular (Articles) ---
model Extracurricular {
  id           String     @id @default(cuid())
  title        String
  slug         String     @unique
  ekskul_name  EkskulName
  content      String     @db.Text
  thumbnail    String?
  is_published Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum EkskulName {
  Pramuka
  Paskibraka
  Sains_Club
  Basket
  Voli
  Seni_Tari
  Paduan_Suara
  PMR
  Jurnalistik
}

// --- Modul: Facilities (Sarpras) ---
model Facility {
  id        String   @id @default(cuid())
  name      String
  quantity  Int      @default(1)
  image_url String?
  createdAt DateTime @default(now())
}

// --- Modul: Calendar (Holidays) ---
model Holiday {
  id          String   @id @default(cuid())
  date        DateTime // Tanggal perayaan
  description String   // Nama perayaan/libur
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- Modul: Jadwal Pelajaran (School Schedule) ---
model SchoolSchedule {
  id          String   @id @default(cuid())
  class_name  String
  period      String
  time        String
  subject     String
  day_of_week String
  teacher_nip String?
  teacher     EducationPersonnel? @relation(fields: [teacher_nip], references: [nip], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}