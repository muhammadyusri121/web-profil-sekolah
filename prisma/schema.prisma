generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// MODELS (sesuai dengan CMS Admin)
// ==========================================

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  nip         String?  @unique
  password    String
  name        String
  role        Role     @default(OPERATOR)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  permissions String[] @default([])
}

model EducationPersonnel {
  id         String           @id @default(cuid())
  full_name  String
  nip        String?          @unique
  email      String?
  position   String
  image_url  String?
  sort_order Int              @default(0)
  createdAt  DateTime         @default(now())
  schedules  SchoolSchedule[]
}

model Post {
  id           String       @id @default(cuid())
  title        String
  slug         String       @unique
  content      String
  category     PostCategory
  images       String[]
  is_published Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Graduation {
  id              String   @id @default(cuid())
  nisn            String   @unique
  student_name    String
  birthday        String?
  gender          String?
  class_name      String?
  is_graduated    Boolean  @default(false)
  graduation_year Int
  createdAt       DateTime @default(now())
}

model AcademicDocument {
  id        String   @id @default(cuid())
  file_name String
  file_path String
  doc_type  DocType
  createdAt DateTime @default(now())
}

model Extracurricular {
  id           String     @id @default(cuid())
  title        String
  slug         String     @unique
  ekskul_name  EkskulName
  content      String
  thumbnail    String?
  is_published Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Facility {
  id        String   @id @default(cuid())
  name      String
  quantity  Int      @default(1)
  image_url String?
  createdAt DateTime @default(now())
}

model Holiday {
  id          String   @id @default(cuid())
  date        DateTime
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PeriodTime {
  id        Int              @id
  time      String
  schedules SchoolSchedule[]
}

model SchoolSchedule {
  id          String              @id @default(cuid())
  class_name  String
  subject     String
  teacher_nip String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  period      Int
  day_of_week DayOfWeek
  period_time PeriodTime          @relation(fields: [period], references: [id])
  teacher     EducationPersonnel? @relation(fields: [teacher_nip], references: [nip])
}

model SectionHeader {
  id          String   @id
  slug        String   @unique
  title       String
  description String?
  updatedAt   DateTime
}

model VisitorLog {
  id        String   @id
  ipHash    String
  path      String
  country   String?
  visitedAt DateTime @default(now())
}

model VisitorStatistic {
  id        String   @id
  path      String   @unique
  count     Int      @default(0)
  updatedAt DateTime
}

// --- Modul: School Profile (khusus Website, tidak ada di CMS Admin) ---
model SchoolProfile {
  id              String   @id @default(cuid())
  principalName   String
  principalImage  String?
  welcomeMessage  String   @db.Text
  vision          String   @db.Text
  mission         String   @db.Text
  updatedAt       DateTime @updatedAt
  updatedBy       String?
}

// ==========================================
// ENUMS (sesuai dengan CMS Admin)
// ==========================================

enum DayOfWeek {
  Senin
  Selasa
  Rabu
  Kamis
  Jumat
  Sabtu
}

enum Role {
  ADMIN
  OPERATOR
  KONTRIBUTOR
}

enum PostCategory {
  SUPERVISI_GURU
  ASAS
  ASAJ
  TKA
  KARYA_SISWA
  HUMAS
  KOMITE
  KEMITRAAN
  DOUBLE_TRACK
  OSIS_MPK
}

enum DocType {
  REGULATION
  SCHEDULE
  TEACHING_MATERIAL
}

enum EkskulName {
  Pramuka
  Paskibraka
  Sains_Club
  Basket
  Voli
  Seni_Tari
  Paduan_Suara
  PMR
  Jurnalistik
}
